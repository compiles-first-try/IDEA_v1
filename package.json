{
  "name": "rsf",
  "version": "1.0.0",
  "private": true,
  "description": "Recursive Software Foundry — self-sustaining software manufacturing system",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:contracts": "bash scripts/gate4-contract-tests.sh",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "gate1": "bash scripts/gate1-env-audit.sh",
    "gate2": "bash scripts/gate2-deps-resolve.sh",
    "gate3": "bash scripts/gate3-infra-health.sh",
    "gate4": "bash scripts/gate4-contract-tests.sh",
    "gate5": "bash scripts/gate5-phase-validate.sh",
    "kill": "bash scripts/kill-switch.sh",
    "improve": "echo 'Meta-improvement not yet implemented'",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:ps": "docker compose ps"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ]
  }
}
