# ─── Anthropic API ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── PostgreSQL ───
POSTGRES_URL=postgresql://rsf_user:rsf_password@localhost:5432/rsf_db
POSTGRES_USER=rsf_user
POSTGRES_PASSWORD=rsf_password
POSTGRES_DB=rsf_db

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Temporal ───
TEMPORAL_ADDRESS=localhost:7233

# ─── Ollama ───
OLLAMA_BASE_URL=http://localhost:11434

# ─── Kill Switch ───
FOUNDRY_KILL=0

# ─── Budget ───
MAX_DAILY_CLOUD_SPEND_USD=10

# ─── Observability ───
JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=rsf

# ─── Logging ───
LOG_LEVEL=info
AUDIT_LOG_PATH=./logs/audit.jsonl
